{
  "mcpServers": {
    "azure-specs": {
      "type": "stdio",
      "command": "python3",
      "args": [".github/mcp/azure-specs-server.py"],
      "env": {
        "AZURE_SPECS_ROOT": "specs/azure-rest-api-specs/specification"
      }
    },
    "msgraph-specs": {
      "type": "stdio",
      "command": "python3",
      "args": [".github/mcp/msgraph-specs-server.py"],
      "env": {
        "MSGRAPH_SPECS_ROOT": "specs/msgraph-metadata"
      }
    },
    "github-specs": {
      "type": "stdio",
      "command": "python3",
      "args": [".github/mcp/github-specs-server.py"],
      "env": {
        "GITHUB_SPECS_ROOT": "specs/rest-api-description"
      }
    },
    "kubernetes-specs": {
      "type": "stdio",
      "command": "python3",
      "args": [".github/mcp/kubernetes-specs-server.py"],
      "env": {
        "K8S_SPECS_ROOT": "specs/kubernetes"
      }
    },
    "drawio": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "drawio-mcp-server", "--editor"]
    }
  }
}
