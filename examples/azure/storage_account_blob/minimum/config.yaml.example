---
# Minimum configuration for azure_storage_account_blobs
# Run from the repo root:
#   export TF_VAR_storage_access_token=$(az account get-access-token \
#     --resource https://storage.azure.com --query accessToken -o tsv)
#   export TF_VAR_storage_account_name=mystorageaccount
#   terraform apply -var config_file=configurations/storage_account_blobs.yaml

terraform_backend:
  type: local

azure_storage_account_blobs:
  minimum:
    account_name:   mystorageaccount
    container_name: mycontainer
    blob_name:      example/hello.txt
