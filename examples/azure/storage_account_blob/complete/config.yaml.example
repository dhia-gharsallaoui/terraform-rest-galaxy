---
# Complete configuration for azure_storage_account_blobs
# Run from the repo root:
#   export TF_VAR_storage_access_token=$(az account get-access-token \
#     --resource https://storage.azure.com --query accessToken -o tsv)
#   export TF_VAR_storage_account_name=mystorageaccount
#   terraform apply -var config_file=configurations/storage_account_blobs.yaml

terraform_backend:
  type: local

azure_storage_account_blobs:
  app_config:
    account_name:   mystorageaccount
    container_name: app-configs
    blob_name:      production/config.json
    content_type:   application/json
    content:        '{"environment":"production","debug":false}'
    access_tier:    Hot
    metadata:
      team:        platform
      environment: production
      managed-by:  terraform

  readme:
    account_name:   mystorageaccount
    container_name: app-configs
    blob_name:      README.md
    content_type:   text/plain
    content:        "This container holds application configuration files."
    access_tier:    Cool
