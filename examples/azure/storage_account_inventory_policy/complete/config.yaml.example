default_location: westeurope

# Complete example — three rules covering Blob (Weekly Parquet + Daily CSV) and Container inventory.
# All destination containers must exist before applying.

azure_storage_account_inventory_policies:
  full-inventory:
    subscription_id:     "00000000-0000-0000-0000-000000000000"
    resource_group_name: rg-data
    account_name:        mydatalake001
    rules:
      - name:                  weekly-blob-parquet
        enabled:               true
        destination:           inventory-reports
        schedule:              Weekly
        object_type:           Blob
        format:                Parquet
        include_snapshots:     true
        include_blob_versions: true
        include_deleted:       false
        blob_types:
          - blockBlob
          - appendBlob
        prefix_match:
          - data/2024/
          - data/2025/
        schema_fields:
          - Name
          - Creation-Time
          - Last-Modified
          - Content-Length
          - BlobType
          - AccessTier
          - Snapshot
          - VersionId
          - IsCurrentVersion

      - name:        daily-blob-csv
        enabled:     true
        destination: inventory-reports
        schedule:    Daily
        object_type: Blob
        format:      Csv
        blob_types:
          - blockBlob
        schema_fields:
          - Name
          - Last-Modified
          - BlobType
          - AccessTier

      - name:        weekly-container-inventory
        enabled:     true
        destination: inventory-reports
        schedule:    Weekly
        object_type: Container
        format:      Csv
        schema_fields:
          - Name
          - Last-Modified
          - PublicAccess
          - LeaseStatus
          - HasImmutabilityPolicy
