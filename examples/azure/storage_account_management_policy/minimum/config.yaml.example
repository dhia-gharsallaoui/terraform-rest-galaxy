# Root-module equivalent configuration for the minimum example.
# Drive via: TF_VAR_config_file=config.yaml.example terraform apply
#
# Prerequisites: the referenced storage account must already exist.

default_location: westeurope

azure_storage_account_management_policies:
  minimum:
    subscription_id: "00000000-0000-0000-0000-000000000000"
    resource_group_name: rg-data
    account_name: mydatalake001
    rules:
      - name: delete-not-accessed
        enabled: true
        filters:
          blob_types:
            - blockBlob
        actions:
          base_blob:
            delete_after_days_since_last_access_time_greater_than: 90
