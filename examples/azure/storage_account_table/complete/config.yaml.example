# Storage Account Table — complete configuration example
# Demonstrates all configurable properties including signed identifiers.
# Usage: TF_VAR_config_file=config.yaml terraform apply

default_location: westeurope

azure_storage_account_tables:
  events:
    subscription_id: "00000000-0000-0000-0000-000000000000"
    resource_group_name: rg-myapp
    account_name: stmyapp001
    table_name: EventsTable
    signed_identifiers:
      - id: readpolicy
        access_policy:
          start_time: "2025-01-01T00:00:00Z"
          expiry_time: "2026-01-01T00:00:00Z"
          permission: r
  metrics:
    subscription_id: "00000000-0000-0000-0000-000000000000"
    resource_group_name: rg-myapp
    account_name: stmyapp001
    table_name: MetricsTable
